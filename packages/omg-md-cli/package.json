{
  "name": "omg-md-cli",
  "version": "0.4.1",
  "description": "CLI for OMG (OpenAPI Markdown Grammar)",
  "author": "mcclowes",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcclowes/omg.git",
    "directory": "packages/omg-md-cli"
  },
  "bugs": {
    "url": "https://github.com/mcclowes/omg/issues"
  },
  "homepage": "https://github.com/mcclowes/omg/tree/main/packages/omg-md-cli#readme",
  "keywords": [
    "openapi",
    "omg",
    "cli",
    "command-line",
    "api",
    "specification",
    "compiler"
  ],
  "main": "dist/index.js",
  "bin": {
