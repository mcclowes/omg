    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "yaml": "^2.3.4",
    "js-yaml": "^4.1.0",
    "vague-lang": "^3.2.0",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "esbuild": "^0.24.0",
    "omg-linter": "^0.4.1",
    "omg-importer": "^0.4.1",
    "omg-mock-server": "^0.4.1"
  }
